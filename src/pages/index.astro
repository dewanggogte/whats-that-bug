---
import Base from '../layouts/Base.astro';
import setsData from '../../public/data/sets.json';
import observations from '../../public/data/observations.json';

const THEMED_SETS = [
  { key: 'backyard_basics', icon: '🏡' },
  { key: 'tiny_terrors', icon: '😱' },
  { key: 'beetles', icon: '🪲' },
  { key: 'butterflies_moths', icon: '🦋' },
  { key: 'spiders', icon: '🕷️' },
  { key: 'eye_candy', icon: '📸' },
];

const themedGroup = THEMED_SETS.map(({ key, icon }) => {
  const set = setsData[key];
  const uniqueSpecies = new Set(
    set.observation_ids.map((i: number) => observations[i]?.taxon?.species)
  ).size;
  return { key, name: set.name, icon, countLabel: `${uniqueSpecies} species` };
});
---
<Base
  title="What's That Bug? — The Insect Identification Game"
  description="A free guess-the-bug game with 1,000+ species. Can you identify insects from real research-grade photos? Test your insect ID skills in this GeoGuessr-style quiz."
  canonicalPath="/"
>
  <div class="container">
    <div style="text-align: center; padding: 24px 0 8px;">
      <h1>🪲 What's That Bug?</h1>
      <p class="subtitle">Can you identify insects from their photos? Pick a mode and find out.</p>
    </div>

    <div class="mode-group" style="border: 2px solid var(--accent); border-radius: 12px;">
      <div class="mode-group-header">
        <div>
          <h2 class="mode-group-title">📅 Daily Challenge <span class="diff-badge" style="background:var(--accent);color:white;">New</span></h2>
          <p class="mode-group-subtitle">A new mystery insect every day. Same puzzle for everyone.</p>
        </div>
      </div>
      <div class="mode-buttons">
        <a href="/daily/play?mode=bugs101" class="mode-btn">
          <span class="mode-btn-icon">🔰</span>
          <span class="mode-btn-label">Bugs 101</span>
          <span class="mode-btn-desc" id="hp-status-bugs101">Name the type</span>
          <span class="daily-card-streak" id="hp-streak-bugs101"></span>
        </a>
        <a href="/daily/play?mode=allbugs" class="mode-btn">
          <span class="mode-btn-icon">🌍</span>
          <span class="mode-btn-label">All Bugs</span>
          <span class="mode-btn-desc" id="hp-status-allbugs">Name the species</span>
          <span class="daily-card-streak" id="hp-streak-allbugs"></span>
        </a>
      </div>
    </div>

    <div class="mode-group">
      <div class="mode-group-header">
        <div>
          <h2 class="mode-group-title">🔰 Bugs 101 <span class="diff-badge diff-beginner">Beginner</span></h2>
          <p class="mode-group-subtitle">Identify by type — beetle, spider, butterfly, and more</p>
        </div>
      </div>
      <div class="mode-buttons">
        <a href="/play?set=bugs_101_time_trial" class="mode-btn">
          <span class="mode-btn-icon">⏱️</span>
          <span class="mode-btn-label">Time Trial</span>
          <span class="mode-btn-desc">60 seconds</span>
        </a>
        <a href="/play?set=bugs_101_streak" class="mode-btn">
          <span class="mode-btn-icon">🎯</span>
          <span class="mode-btn-label">Streaks</span>
          <span class="mode-btn-desc">Don't miss</span>
        </a>
        <a href="/play?set=bugs_101" class="mode-btn">
          <span class="mode-btn-icon">🔰</span>
          <span class="mode-btn-label">Classic</span>
          <span class="mode-btn-desc">10 rounds</span>
        </a>
      </div>
    </div>

    <div class="mode-group">
      <div class="mode-group-header">
        <div>
          <h2 class="mode-group-title">🌍 All Bugs <span class="diff-badge diff-expert">Expert</span></h2>
          <p class="mode-group-subtitle">Name the exact species from 1,000+ bugs worldwide</p>
        </div>
      </div>
      <div class="mode-buttons">
        <a href="/play?set=time_trial" class="mode-btn">
          <span class="mode-btn-icon">⏱️</span>
          <span class="mode-btn-label">Time Trial</span>
          <span class="mode-btn-desc">60 seconds</span>
        </a>
        <a href="/play?set=streak" class="mode-btn">
          <span class="mode-btn-icon">🎯</span>
          <span class="mode-btn-label">Streaks</span>
          <span class="mode-btn-desc">Don't miss</span>
        </a>
        <a href="/play?set=all_bugs" class="mode-btn">
          <span class="mode-btn-icon">🌍</span>
          <span class="mode-btn-label">Classic</span>
          <span class="mode-btn-desc">10 rounds</span>
        </a>
      </div>
    </div>

    <div class="mode-group" style="margin-top: 20px;">
      <div class="mode-group-header">
        <div>
          <h2 class="mode-group-title">Themed Sets <span class="diff-badge diff-intermediate">Intermediate</span></h2>
          <p class="mode-group-subtitle">Dive deeper into specific groups</p>
        </div>
      </div>
      <div class="themed-buttons">
        {themedGroup.map(set => (
          <a href={`/play?set=${set.key}`} class="themed-btn">
            <span class="themed-btn-icon">{set.icon}</span>
            <span class="themed-btn-label">{set.name}</span>
            <span class="themed-btn-meta">{set.countLabel}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script>
    // Show best scores from localStorage
    const bestKeys = [
      'bugs_101_time_trial', 'bugs_101_streak', 'bugs_101',
      'time_trial', 'streak', 'all_bugs',
      'backyard_basics', 'tiny_terrors', 'beetles', 'butterflies_moths', 'spiders', 'eye_candy',
    ];
    // Best scores are shown inline on mode buttons via data attributes
    document.querySelectorAll('.mode-btn[data-key], .themed-btn[data-key]').forEach(el => {
      const key = el.getAttribute('data-key');
      if (!key) return;
      const best = localStorage.getItem(`best_${key}`);
      if (best) {
        const meta = el.querySelector('.mode-btn-desc, .themed-btn-meta');
        if (meta) {
          meta.textContent = `Best: ${best}`;
          meta.style.color = 'var(--accent)';
        }
      }
    });
  </script>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "What's That Bug?",
    "description": "A free guess-the-bug game with 1,000+ species. Identify insects from real research-grade photos in this GeoGuessr-style quiz.",
    "url": "https://dewanggogte.com/games/bugs",
    "applicationCategory": "GameApplication",
    "genre": "Trivia",
    "operatingSystem": "Web",
    "browserRequirements": "Requires JavaScript",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Person",
      "name": "Dewang Gogte",
      "url": "https://dewanggogte.com"
    }
  }
  </script>

<script>
  import { getTodayET, loadDailyState, loadHistory, calculateStreaks } from '../scripts/daily-engine.js';

  try {
    const today = getTodayET();
    ['bugs101', 'allbugs'].forEach(mode => {
      const result = loadDailyState(mode, today);
      const statusEl = document.getElementById(`hp-status-${mode}`);
      const streakEl = document.getElementById(`hp-streak-${mode}`);
      const maxG = mode === 'bugs101' ? 3 : 6;

      if (result && statusEl) {
        statusEl.textContent = result.solved
          ? `Solved in ${result.guesses}/${maxG}!`
          : `Missed today`;
        statusEl.style.color = result.solved ? 'var(--success)' : 'var(--error)';
      }

      const history = loadHistory(mode);
      const streaks = calculateStreaks(history, today);
      if (streaks.playStreak > 0 && streakEl) {
        streakEl.textContent = `${streaks.playStreak} day streak`;
      }

      // Streak at risk warning
      if (streaks.playStreak >= 3 && !result) {
        const streakWarning = document.createElement('div');
        streakWarning.className = 'streak-warning';
        streakWarning.textContent = `${streaks.playStreak}-day streak at risk!`;
        const dailyGroup = document.querySelector('.mode-group[style*="border"]');
        if (dailyGroup) {
          const header = dailyGroup.querySelector('.mode-group-header');
          if (header) header.appendChild(streakWarning);
        }
      }
    });
  } catch { /* daily challenge not yet available */ }
</script>

<script>
  import { runOnboarding } from '../scripts/onboarding.js';
  import { maybeShowSupportPrompt } from '../scripts/support-prompt.js';
  runOnboarding();
  maybeShowSupportPrompt();
</script>

<script>
  // --- Player Stats Card ---
  try {
    const { getEarnedAchievements, getSpeciesCount, ACHIEVEMENT_DEFS } = await import('../scripts/achievements.js');
    const stats = JSON.parse(localStorage.getItem('wtb_player_stats') || '{}');
    const speciesCount = getSpeciesCount();
    const sessionCount = stats.session_count || 0;
    const achievements = getEarnedAchievements();

    // Only show stats card if player has at least 3 sessions
    if (sessionCount >= 3) {
      const statsCard = document.createElement('div');
      statsCard.className = 'player-stats-card';
      statsCard.innerHTML = `
        <div class="stats-row">
          <button class="stat-item stat-item-btn" data-modal="sessions">
            <span class="stat-value">${sessionCount}</span>
            <span class="stat-label">sessions</span>
          </button>
          <button class="stat-item stat-item-btn" data-modal="species">
            <span class="stat-value">${speciesCount}</span>
            <span class="stat-label">species ID'd</span>
          </button>
          <button class="stat-item stat-item-btn" data-modal="badges">
            <span class="stat-value">${achievements.length}</span>
            <span class="stat-label">badges</span>
          </button>
        </div>
      `;

      const container = document.querySelector('.container');
      const firstModeGroup = container.querySelector('.mode-group');
      if (firstModeGroup) {
        container.insertBefore(statsCard, firstModeGroup);
      }

      // --- Modal system ---
      const overlay = document.createElement('div');
      overlay.className = 'stats-modal-overlay';
      overlay.innerHTML = `
        <div class="stats-modal">
          <div class="stats-modal-header">
            <h2 class="stats-modal-title"></h2>
            <button class="stats-modal-close" aria-label="Close">&times;</button>
          </div>
          <div class="stats-modal-body"></div>
        </div>
      `;
      document.body.appendChild(overlay);

      const modalTitle = overlay.querySelector('.stats-modal-title');
      const modalBody = overlay.querySelector('.stats-modal-body');
      const closeBtn = overlay.querySelector('.stats-modal-close');

      function openModal(title, html) {
        modalTitle.textContent = title;
        modalBody.innerHTML = html;
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function closeModal() {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }
      closeBtn.addEventListener('click', closeModal);
      overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

      // --- Sessions modal ---
      function buildSessionsModal() {
        const lastPlayed = stats.last_played
          ? new Date(stats.last_played).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })
          : 'Unknown';

        // Gather best scores
        const scoreKeys = [
          { key: 'bugs_101', label: 'Bugs 101 Classic' },
          { key: 'bugs_101_time_trial', label: 'Bugs 101 Time Trial' },
          { key: 'bugs_101_streak', label: 'Bugs 101 Streak' },
          { key: 'all_bugs', label: 'All Bugs Classic' },
          { key: 'time_trial', label: 'All Bugs Time Trial' },
          { key: 'streak', label: 'All Bugs Streak' },
          { key: 'backyard_basics', label: 'Backyard Basics' },
          { key: 'tiny_terrors', label: 'Tiny Terrors' },
          { key: 'beetles', label: 'Beetles' },
          { key: 'butterflies_moths', label: 'Butterflies & Moths' },
          { key: 'spiders', label: 'Spiders' },
          { key: 'eye_candy', label: 'Eye Candy' },
        ];

        const scores = scoreKeys
          .map(s => ({ ...s, score: localStorage.getItem(`best_${s.key}`) }))
          .filter(s => s.score);

        return `
          <div class="sessions-detail">
            <div class="sessions-summary">
              <div class="sessions-stat">
                <span class="sessions-stat-val">${sessionCount}</span>
                <span class="sessions-stat-lbl">Total Sessions</span>
              </div>
              <div class="sessions-stat">
                <span class="sessions-stat-val">${lastPlayed}</span>
                <span class="sessions-stat-lbl">Last Played</span>
              </div>
              <div class="sessions-stat">
                <span class="sessions-stat-val">${speciesCount}</span>
                <span class="sessions-stat-lbl">Unique Species</span>
              </div>
            </div>
            ${scores.length > 0 ? `
              <h3 class="sessions-section-title">Best Scores</h3>
              <div class="sessions-scores">
                ${scores.map(s => `
                  <div class="sessions-score-row">
                    <span class="sessions-score-label">${s.label}</span>
                    <span class="sessions-score-value">${s.score}</span>
                  </div>
                `).join('')}
              </div>
            ` : '<p style="color:var(--text-secondary);text-align:center;margin-top:16px;">Play more games to see your best scores here.</p>'}
          </div>
        `;
      }

      // --- Species modal ---
      async function buildSpeciesModal() {
        const seenSpecies = JSON.parse(localStorage.getItem('wtb_species_seen') || '[]');
        if (seenSpecies.length === 0) {
          return '<p style="color:var(--text-secondary);text-align:center;padding:24px;">No species identified yet. Play a game to start your collection!</p>';
        }

        // Load observations data
        const basePath = window.__BASE || '';
        const resp = await fetch(`${basePath}/data/observations.json`);
        const observations = await resp.json();

        // Build a lookup: species name → best observation (prefer one with wikipedia_summary)
        const speciesMap = new Map();
        for (const obs of observations) {
          const name = obs.taxon?.species;
          if (!name || !seenSpecies.includes(name)) continue;
          const existing = speciesMap.get(name);
          if (!existing || (!existing.wikipedia_summary && obs.wikipedia_summary)) {
            speciesMap.set(name, obs);
          }
        }

        const cards = seenSpecies
          .filter(name => speciesMap.has(name))
          .sort()
          .map(name => {
            const obs = speciesMap.get(name);
            const common = obs.taxon?.common_name || '';
            const summary = obs.wikipedia_summary
              ? obs.wikipedia_summary.slice(0, 100) + (obs.wikipedia_summary.length > 100 ? '...' : '')
              : obs.taxon?.order_common || '';
            return `
              <div class="species-card">
                <div class="species-card-img" style="background-image:url('${obs.photo_url}')"></div>
                <div class="species-card-info">
                  <span class="species-card-common">${common || name}</span>
                  <span class="species-card-sci">${name}</span>
                  <span class="species-card-blurb">${summary}</span>
                </div>
              </div>
            `;
          });

        return `<div class="species-grid">${cards.join('')}</div>`;
      }

      // --- Badges modal ---
      function badgeShareText(def) {
        const rarityLabel = { common: '', uncommon: '', rare: 'Rare ', very_rare: 'Very Rare ', epic: 'Epic ', legendary: 'Legendary ' };
        const prefix = rarityLabel[def.rarity] || '';
        return [
          `I just earned the ${prefix}"${def.name}" badge on What's That Bug!`,
          '',
          `${def.icon} ${def.name} — ${def.description}`,
          '',
          `${achievements.length}/${ACHIEVEMENT_DEFS.length} badges collected. Can you beat that?`,
          '',
          'https://dewanggogte.com/games/bugs/?ref=share',
        ].join('\n');
      }

      function buildBadgesModal() {
        const earnedIds = new Set(achievements.map(a => a.id));
        const rarityLabel = { common: 'Common', uncommon: 'Uncommon', rare: 'Rare', very_rare: 'Very Rare', epic: 'Epic', legendary: 'Legendary' };
        const rarityColor = { common: '#666', uncommon: '#059669', rare: '#3b6eb8', very_rare: '#a855f7', epic: '#c44b2b', legendary: '#b8953b' };

        const shareIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>';

        const cards = ACHIEVEMENT_DEFS.map(def => {
          const earned = earnedIds.has(def.id);
          const basePath = window.__BASE || '';
          return `
            <div class="badge-card ${earned ? '' : 'badge-locked'}">
              <img class="badge-card-img" src="${basePath}/badges/${def.id}.svg" alt="${def.name}" width="80" height="80" />
              <span class="badge-card-name">${def.name}</span>
              <span class="badge-card-desc">${def.description}</span>
              <span class="badge-card-rarity" style="color:${rarityColor[def.rarity] || '#666'}">${rarityLabel[def.rarity] || def.rarity}</span>
              ${earned ? `<button class="badge-share-btn" data-badge-id="${def.id}" title="Share this badge">${shareIcon} Share</button>` : ''}
            </div>
          `;
        });

        return `
          <div class="badge-summary">${achievements.length} of ${ACHIEVEMENT_DEFS.length} earned</div>
          <div class="badges-grid">${cards.join('')}</div>
        `;
      }

      function attachBadgeShareHandlers() {
        modalBody.querySelectorAll('.badge-share-btn').forEach(btn => {
          btn.addEventListener('click', async () => {
            const def = ACHIEVEMENT_DEFS.find(d => d.id === btn.dataset.badgeId);
            if (!def) return;
            const text = badgeShareText(def);
            if (typeof navigator !== 'undefined' && navigator.share) {
              try { await navigator.share({ text }); } catch {}
            } else {
              try {
                await navigator.clipboard.writeText(text);
                btn.innerHTML = '&#10003; Copied!';
              } catch {
                btn.textContent = 'Failed';
              }
              setTimeout(() => {
                const shareIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>';
                btn.innerHTML = `${shareIcon} Share`;
              }, 2000);
            }
          });
        });
      }

      // --- Click handlers ---
      statsCard.querySelectorAll('.stat-item-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const modal = btn.dataset.modal;
          if (modal === 'sessions') {
            openModal('Your Sessions', buildSessionsModal());
          } else if (modal === 'species') {
            openModal('Species Collection', '<p style="text-align:center;padding:24px;color:var(--text-secondary);">Loading species...</p>');
            const html = await buildSpeciesModal();
            modalBody.innerHTML = html;
          } else if (modal === 'badges') {
            openModal('Badge Collection', buildBadgesModal());
            attachBadgeShareHandlers();
          }
        });
      });
    }

    // Species milestone — show once per milestone
    const milestones = [50, 100, 150, 200, 250, 500, 1000];
    const milestone = milestones.filter(m => speciesCount >= m).pop();
    const lastCelebrated = parseInt(localStorage.getItem('wtb_last_milestone') || '0', 10);

    if (milestone && milestone > lastCelebrated) {
      localStorage.setItem('wtb_last_milestone', milestone.toString());
      localStorage.setItem('wtb_show_milestone', milestone.toString());
    }

    const pendingMilestone = localStorage.getItem('wtb_show_milestone');
    if (pendingMilestone) {
      localStorage.removeItem('wtb_show_milestone');
      const banner = document.createElement('div');
      banner.className = 'milestone-banner';
      banner.innerHTML = `🎉 You've identified <strong>${pendingMilestone}</strong> unique species!`;
      const container = document.querySelector('.container');
      container.insertBefore(banner, container.firstChild);
      setTimeout(() => { banner.style.opacity = '0'; setTimeout(() => banner.remove(), 500); }, 5000);
    }
  } catch { /* ignore — non-critical UI enhancement */ }
</script>

<style is:global>
  .player-stats-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 20px;
  }

  .stats-row {
    display: flex;
    justify-content: space-around;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-item-btn {
    background: none;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    padding: 8px 16px;
    cursor: pointer;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }
  .stat-item-btn:hover {
    background: var(--bg);
    border-color: var(--border);
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .streak-warning {
    display: inline-block;
    margin-top: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--error);
    animation: pulse 2s ease-in-out infinite;
  }

  .milestone-banner {
    background: var(--accent);
    color: white;
    text-align: center;
    padding: 12px 16px;
    border-radius: 12px;
    margin-bottom: 16px;
    font-size: 0.95rem;
    transition: opacity 500ms ease-out;
  }

  /* --- Stats Modal --- */
  .stats-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-modal), visibility var(--transition-modal);
    padding: 16px;
  }
  .stats-modal-overlay.open {
    opacity: 1;
    visibility: visible;
  }
  .stats-modal {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    width: 100%;
    max-width: 520px;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    transform: translateY(12px);
    transition: transform var(--transition-modal);
  }
  .stats-modal-overlay.open .stats-modal {
    transform: translateY(0);
  }
  .stats-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .stats-modal-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0;
  }
  .stats-modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--text-secondary);
    padding: 0 4px;
    line-height: 1;
  }
  .stats-modal-close:hover { color: var(--text); }
  .stats-modal-body {
    padding: 20px;
    overflow-y: auto;
    flex: 1;
  }

  /* --- Sessions detail --- */
  .sessions-summary {
    display: flex;
    justify-content: space-around;
    text-align: center;
    margin-bottom: 20px;
  }
  .sessions-stat {
    display: flex;
