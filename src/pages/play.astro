---
import Base from '../layouts/Base.astro';
---
<Base
  title="Identify This Bug — What's That Bug?"
  description="Can you identify the insect from its photo? Four choices, one correct answer. Test your bug identification skills with real research-grade photos."
  canonicalPath="/play"
>
  <div id="game-container">
    <div class="container" style="text-align: center; padding-top: 80px;">
      <p class="subtitle">Loading bugs...</p>
    </div>
  </div>
  <script>
    import { logPlayLanding } from '../scripts/feedback.js';
    import { initGame } from '../scripts/game-ui.js';
    const setParam = new URLSearchParams(window.location.search).get('set');
    logPlayLanding(setParam);
    initGame();
  </script>
</Base>
