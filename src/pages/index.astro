---
import Base from '../layouts/Base.astro';
import setsData from '../../public/data/sets.json';
import observations from '../../public/data/observations.json';

const THEMED_SETS = [
  { key: 'backyard_basics', icon: '🏡' },
  { key: 'tiny_terrors', icon: '😱' },
  { key: 'beetles', icon: '🪲' },
  { key: 'butterflies_moths', icon: '🦋' },
  { key: 'spiders', icon: '🕷️' },
];

const themedGroup = THEMED_SETS.map(({ key, icon }) => {
  const set = setsData[key];
  const uniqueSpecies = new Set(
    set.observation_ids.map((i: number) => observations[i]?.taxon?.species)
  ).size;
  return { key, name: set.name, icon, countLabel: `${uniqueSpecies} species` };
});
---
<Base
  title="What's That Bug? — The Insect Identification Game"
  description="A free guess-the-bug game with 1,000+ species. Can you identify insects from real research-grade photos? Test your insect ID skills in this GeoGuessr-style quiz."
  canonicalPath="/"
>
  <div class="container">
    <div style="text-align: center; padding: 24px 0 8px;">
      <h1>🪲 What's That Bug?</h1>
      <p class="subtitle">Can you identify insects from their photos? Pick a mode and find out.</p>
    </div>

    <div class="mode-group" style="border: 2px solid var(--accent); border-radius: 12px;">
      <div class="mode-group-header">
        <div>
          <h2 class="mode-group-title">📅 Daily Challenge <span class="diff-badge" style="background:var(--accent);color:white;">New</span></h2>
          <p class="mode-group-subtitle">A new mystery insect every day. Same puzzle for everyone.</p>
        </div>
      </div>
      <div class="mode-buttons">
        <a href="/daily/play?mode=bugs101" class="mode-btn">
          <span class="mode-btn-icon">🔰</span>
          <span class="mode-btn-label">Bugs 101</span>
          <span class="mode-btn-desc" id="hp-status-bugs101">Name the type</span>
          <span class="daily-card-streak" id="hp-streak-bugs101"></span>
        </a>
        <a href="/daily/play?mode=allbugs" class="mode-btn">
          <span class="mode-btn-icon">🌍</span>
          <span class="mode-btn-label">All Bugs</span>
          <span class="mode-btn-desc" id="hp-status-allbugs">Name the species</span>
          <span class="daily-card-streak" id="hp-streak-allbugs"></span>
        </a>
      </div>
    </div>

    <div class="mode-group">
      <div class="mode-group-header">
        <div>
          <h2 class="mode-group-title">🔰 Bugs 101 <span class="diff-badge diff-beginner">Beginner</span></h2>
          <p class="mode-group-subtitle">Identify by type — beetle, spider, butterfly, and more</p>
        </div>
      </div>
      <div class="mode-buttons">
        <a href="/play?set=bugs_101_time_trial" class="mode-btn">
          <span class="mode-btn-icon">⏱️</span>
          <span class="mode-btn-label">Time Trial</span>
          <span class="mode-btn-desc">60 seconds</span>
        </a>
        <a href="/play?set=bugs_101_streak" class="mode-btn">
          <span class="mode-btn-icon">🎯</span>
          <span class="mode-btn-label">Streaks</span>
          <span class="mode-btn-desc">Don't miss</span>
        </a>
        <a href="/play?set=bugs_101" class="mode-btn">
          <span class="mode-btn-icon">🔰</span>
          <span class="mode-btn-label">Classic</span>
          <span class="mode-btn-desc">10 rounds</span>
        </a>
      </div>
    </div>

    <div class="mode-group">
      <div class="mode-group-header">
        <div>
          <h2 class="mode-group-title">🌍 All Bugs <span class="diff-badge diff-expert">Expert</span></h2>
          <p class="mode-group-subtitle">Name the exact species from 1,000+ bugs worldwide</p>
        </div>
      </div>
      <div class="mode-buttons">
        <a href="/play?set=time_trial" class="mode-btn">
          <span class="mode-btn-icon">⏱️</span>
          <span class="mode-btn-label">Time Trial</span>
          <span class="mode-btn-desc">60 seconds</span>
        </a>
        <a href="/play?set=streak" class="mode-btn">
          <span class="mode-btn-icon">🎯</span>
          <span class="mode-btn-label">Streaks</span>
          <span class="mode-btn-desc">Don't miss</span>
        </a>
        <a href="/play?set=all_bugs" class="mode-btn">
          <span class="mode-btn-icon">🌍</span>
          <span class="mode-btn-label">Classic</span>
          <span class="mode-btn-desc">10 rounds</span>
        </a>
      </div>
    </div>

    <div class="mode-group" style="margin-top: 20px;">
      <div class="mode-group-header">
        <div>
          <h2 class="mode-group-title">Themed Sets <span class="diff-badge diff-intermediate">Intermediate</span></h2>
          <p class="mode-group-subtitle">Dive deeper into specific groups</p>
        </div>
      </div>
      <div class="themed-buttons">
        {themedGroup.map(set => (
          <a href={`/play?set=${set.key}`} class="themed-btn">
            <span class="themed-btn-icon">{set.icon}</span>
            <span class="themed-btn-label">{set.name}</span>
            <span class="themed-btn-meta">{set.countLabel}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script>
    // Show best scores from localStorage
    const bestKeys = [
      'bugs_101_time_trial', 'bugs_101_streak', 'bugs_101',
      'time_trial', 'streak', 'all_bugs',
      'backyard_basics', 'tiny_terrors', 'beetles', 'butterflies_moths', 'spiders',
    ];
    // Best scores are shown inline on mode buttons via data attributes
    document.querySelectorAll('.mode-btn[data-key], .themed-btn[data-key]').forEach(el => {
      const key = el.getAttribute('data-key');
      if (!key) return;
      const best = localStorage.getItem(`best_${key}`);
      if (best) {
        const meta = el.querySelector('.mode-btn-desc, .themed-btn-meta');
        if (meta) {
          meta.textContent = `Best: ${best}`;
          meta.style.color = 'var(--accent)';
        }
      }
    });
  </script>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "What's That Bug?",
    "description": "A free guess-the-bug game with 1,000+ species. Identify insects from real research-grade photos in this GeoGuessr-style quiz.",
    "url": "https://dewanggogte.com/games/bugs",
    "applicationCategory": "GameApplication",
    "genre": "Trivia",
    "operatingSystem": "Web",
    "browserRequirements": "Requires JavaScript",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Person",
      "name": "Dewang Gogte",
      "url": "https://dewanggogte.com"
    }
  }
  </script>

<script>
  import { getTodayET, loadDailyState, loadHistory, calculateStreaks } from '../scripts/daily-engine.js';

  try {
    const today = getTodayET();
    ['bugs101', 'allbugs'].forEach(mode => {
      const result = loadDailyState(mode, today);
      const statusEl = document.getElementById(`hp-status-${mode}`);
      const streakEl = document.getElementById(`hp-streak-${mode}`);
      const maxG = mode === 'bugs101' ? 3 : 6;

      if (result && statusEl) {
        statusEl.textContent = result.solved
          ? `Solved in ${result.guesses}/${maxG}!`
          : `Missed today`;
        statusEl.style.color = result.solved ? 'var(--success)' : 'var(--error)';
      }

      const history = loadHistory(mode);
      const streaks = calculateStreaks(history, today);
      if (streaks.playStreak > 0 && streakEl) {
        streakEl.textContent = `${streaks.playStreak} day streak`;
      }

      // Streak at risk warning
      if (streaks.playStreak >= 3 && !result) {
        const streakWarning = document.createElement('div');
        streakWarning.className = 'streak-warning';
        streakWarning.textContent = `${streaks.playStreak}-day streak at risk!`;
        const dailyGroup = document.querySelector('.mode-group[style*="border"]');
        if (dailyGroup) {
          const header = dailyGroup.querySelector('.mode-group-header');
          if (header) header.appendChild(streakWarning);
        }
      }
    });
  } catch { /* daily challenge not yet available */ }
</script>

<script>
  import { runOnboarding } from '../scripts/onboarding.js';
  runOnboarding();
</script>

<script>
  // --- Player Stats Card ---
  try {
    const { getEarnedAchievements, getSpeciesCount } = await import('../scripts/achievements.js');
    const stats = JSON.parse(localStorage.getItem('wtb_player_stats') || '{}');
    const speciesCount = getSpeciesCount();
    const sessionCount = stats.session_count || 0;
    const achievements = getEarnedAchievements();

    // Only show stats card if player has at least 3 sessions
    if (sessionCount >= 3) {
      const statsCard = document.createElement('div');
      statsCard.className = 'player-stats-card';
      statsCard.innerHTML = `
        <div class="stats-row">
          <div class="stat-item">
            <span class="stat-value">${sessionCount}</span>
            <span class="stat-label">sessions</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">${speciesCount}</span>
            <span class="stat-label">species ID'd</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">${achievements.length}</span>
            <span class="stat-label">badges</span>
          </div>
        </div>
        ${achievements.length > 0 ? `
          <div class="stats-badges">
            ${achievements.map(a => `<span title="${a.name}: ${a.description}">${a.icon}</span>`).join(' ')}
          </div>
        ` : ''}
      `;

      const container = document.querySelector('.container');
      const firstModeGroup = container.querySelector('.mode-group');
      if (firstModeGroup) {
        container.insertBefore(statsCard, firstModeGroup);
      }
    }

    // Species milestone — show once per milestone
    const milestones = [50, 100, 150, 200, 250, 500, 1000];
    const milestone = milestones.filter(m => speciesCount >= m).pop();
    const lastCelebrated = parseInt(localStorage.getItem('wtb_last_milestone') || '0', 10);

    if (milestone && milestone > lastCelebrated) {
      localStorage.setItem('wtb_last_milestone', milestone.toString());
      localStorage.setItem('wtb_show_milestone', milestone.toString());
    }

    const pendingMilestone = localStorage.getItem('wtb_show_milestone');
    if (pendingMilestone) {
      localStorage.removeItem('wtb_show_milestone');
      const banner = document.createElement('div');
      banner.className = 'milestone-banner';
      banner.innerHTML = `🎉 You've identified <strong>${pendingMilestone}</strong> unique species!`;
      const container = document.querySelector('.container');
      container.insertBefore(banner, container.firstChild);
      setTimeout(() => { banner.style.opacity = '0'; setTimeout(() => banner.remove(), 500); }, 5000);
    }
  } catch { /* ignore — non-critical UI enhancement */ }
</script>

<style is:global>
  .player-stats-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 20px;
  }

  .stats-row {
    display: flex;
    justify-content: space-around;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .stats-badges {
    margin-top: 12px;
    text-align: center;
    font-size: 1.3rem;
    letter-spacing: 4px;
  }

  .streak-warning {
    display: inline-block;
    margin-top: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--error);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  .milestone-banner {
    background: var(--accent);
    color: white;
    text-align: center;
    padding: 12px 16px;
    border-radius: 12px;
    margin-bottom: 16px;
    font-size: 0.95rem;
    transition: opacity 500ms ease-out;
  }
</style>
</Base>
