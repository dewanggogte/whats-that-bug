---
import Base from '../layouts/Base.astro';
---
<Base title="Daily Challenge — What's That Bug?">
  <div class="container">
    <div style="text-align: center; padding: 24px 0 8px;">
      <h1>🪲 Daily Challenge</h1>
      <p class="subtitle">One bug, one chance. Same puzzle for everyone.</p>
    </div>

    <div class="daily-cards">
      <a href="/daily/play?mode=bugs101" class="daily-card" id="card-bugs101">
        <span style="font-size: 24px;">🔰</span>
        <span class="daily-card-title">Bugs 101</span>
        <span class="daily-card-status" id="status-bugs101">3 guesses · Name the type</span>
        <span class="daily-card-streak" id="streak-bugs101"></span>
      </a>
      <a href="/daily/play?mode=allbugs" class="daily-card" id="card-allbugs">
        <span style="font-size: 24px;">🌍</span>
        <span class="daily-card-title">All Bugs</span>
        <span class="daily-card-status" id="status-allbugs">6 guesses · Name the species</span>
        <span class="daily-card-streak" id="streak-allbugs"></span>
      </a>
    </div>

    <div style="text-align: center; margin-top: 24px;">
      <a href="/" style="color: var(--text-secondary); font-size: 14px;">Back to game modes</a>
    </div>
  </div>

  <script>
    import { getTodayET, loadDailyState, loadHistory, calculateStreaks } from '../scripts/daily-engine.js';

    const today = getTodayET();

    ['bugs101', 'allbugs'].forEach(mode => {
      const result = loadDailyState(mode, today);
      const statusEl = document.getElementById(`status-${mode}`);
      const streakEl = document.getElementById(`streak-${mode}`);
      const maxG = mode === 'bugs101' ? 3 : 6;

      if (result) {
        if (result.solved) {
          statusEl.textContent = `Solved in ${result.guesses}/${maxG}!`;
          statusEl.style.color = 'var(--success)';
        } else {
          statusEl.textContent = `Missed — answer: ${result.answer}`;
          statusEl.style.color = 'var(--error)';
        }
      }

      const history = loadHistory(mode);
      const streaks = calculateStreaks(history, today);
      if (streaks.playStreak > 0) {
        streakEl.textContent = `${streaks.playStreak} day streak`;
      }
    });
  </script>
</Base>
