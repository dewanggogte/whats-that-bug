---
import Base from '../layouts/Base.astro';
---
<Base title="About — What's That Bug?">
  <div class="container" style="max-width: 640px;">
    <h1>About What's That Bug?</h1>
    <p class="subtitle" style="margin-bottom: 24px;">A GeoGuessr-style insect identification game.</p>

    <h2>How scoring works</h2>
    <p>Points are based on how taxonomically close your guess is:</p>
    <table style="width: 100%; margin: 12px 0 24px; font-size: 14px; border-collapse: collapse;">
      <thead>
        <tr style="text-align: left; border-bottom: 2px solid var(--border);">
          <th style="padding: 8px 0;">Match Level</th>
          <th style="padding: 8px 0;">Points</th>
          <th style="padding: 8px 0;">Example</th>
        </tr>
      </thead>
      <tbody>
        <tr style="border-bottom: 1px solid var(--border);">
          <td style="padding: 8px 0;">Exact species</td>
          <td style="padding: 8px 0;">🟩 100</td>
          <td style="padding: 8px 0; color: var(--text-secondary);">You nailed it</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--border);">
          <td style="padding: 8px 0;">Same genus</td>
          <td style="padding: 8px 0;">🟨 75</td>
          <td style="padding: 8px 0; color: var(--text-secondary);">Right genus, wrong species</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--border);">
          <td style="padding: 8px 0;">Same family</td>
          <td style="padding: 8px 0;">🟨 50</td>
          <td style="padding: 8px 0; color: var(--text-secondary);">Right family, wrong genus</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--border);">
          <td style="padding: 8px 0;">Same order</td>
          <td style="padding: 8px 0;">🟥 25</td>
          <td style="padding: 8px 0; color: var(--text-secondary);">Right group, wrong family</td>
        </tr>
        <tr>
          <td style="padding: 8px 0;">Wrong order</td>
          <td style="padding: 8px 0;">🟥 0</td>
          <td style="padding: 8px 0; color: var(--text-secondary);">Completely off</td>
        </tr>
      </tbody>
    </table>

    <h2>Where do the photos come from?</h2>
    <p style="margin-bottom: 24px;">
      All photos are from <a href="https://www.inaturalist.org" target="_blank" rel="noopener">iNaturalist</a>,
      a citizen science platform with millions of research-grade observations. Every photo is
      <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY</a> licensed
      and attributed to the original photographer.
    </p>

    <h2>Who built this?</h2>
    <p style="margin-bottom: 24px;">
      This is an open-source project inspired by communities like
      <a href="https://www.reddit.com/r/whatsthisbug/" target="_blank" rel="noopener">r/whatsthisbug</a>.
      Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> and the
      <a href="https://api.inaturalist.org/v1/docs" target="_blank" rel="noopener">iNaturalist API</a>.
    </p>

    <p><a href="/">← Back to game</a></p>
  </div>
</Base>
