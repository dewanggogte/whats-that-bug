---
import Base from '../layouts/Base.astro';
import setsData from '../../public/data/sets.json';
import observations from '../../public/data/observations.json';
import { getCollection } from 'astro:content';

const PRIMARY_SETS = [
  { key: 'bugs_101', icon: '🔰', subtitle: 'Identify by type', detail: 'Beginner' },
  { key: 'all_bugs', icon: '🌍', subtitle: 'Identify the genus', detail: 'Expert' },
];

const MODES = [
  { key: 'classic', icon: '🔟', label: 'Classic', detail: '10 rounds', description: 'A steady quiz with no timer.' },
  { key: 'time_trial', icon: '⏱️', label: 'Time Trial', detail: '60 seconds', description: 'Race the clock for max points.' },
  { key: 'streak', icon: '🎯', label: 'Streaks', detail: 'One miss ends', description: 'Keep going until you miss.' },
];

const THEMED_SETS = [
  { key: 'backyard_basics', icon: '🏡' },
  { key: 'tiny_terrors', icon: '😱' },
  { key: 'beetles', icon: '🪲' },
  { key: 'butterflies_moths', icon: '🦋' },
  { key: 'spiders', icon: '🕷️' },
  { key: 'eye_candy', icon: '📸' },
];

const themedGroup = THEMED_SETS.map(({ key, icon }) => {
  const set = setsData[key];
  const uniqueGenera = new Set(
    set.observation_ids.map((i: number) => observations[i]?.taxon?.genus)
  ).size;
  return { key, name: set.name, icon, countLabel: `${uniqueGenera} genera` };
});

const primaryGroup = PRIMARY_SETS.map(set => ({
  ...set,
  name: setsData[set.key].name,
}));

const latestChangelog = (await getCollection('changelog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmtChangelogDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---
<Base
  title="What's That Bug? — Free Insect Identification Game & Quiz"
  description="Free insect identification game with 1,000+ species. Identify bugs from real research-grade photos in this online quiz. Play daily challenges, chase personal bests, and test your bug ID skills."
  canonicalPath="/"
>
  <div class="container">
    <div style="text-align: center; padding: 28px 0 12px;">
      <h1 style="font-size: 1.8rem; letter-spacing: -0.5px;">What's That Bug?</h1>
      <p class="subtitle">1,000+ species. How many can you name?</p>
    </div>

    <!-- Daily Challenge — subtle banner strip -->
    <div class="daily-banner">
      <span class="daily-banner-text"><strong>Daily Challenge</strong> — a new mystery bug every day</span>
      <span class="daily-banner-status">
        <a href="/daily/play?mode=bugs101" class="daily-banner-link" id="daily-link-bugs101">Play →</a>
      </span>
    </div>

    <!-- Play section — primary CTA -->
    <div class="homepage-section">
      <h2 class="homepage-section-title">Play</h2>
      <p class="homepage-section-subtitle">Choose a set, then pick a mode to start right away.</p>
      <div class="play-cards">
        {primaryGroup.map(set => (
          <div class="set-choice-wrap">
            <button
              type="button"
              class="play-card set-choice-card"
              data-set-card
              data-set-key={set.key}
              data-set-name={set.name}
              data-set-icon={set.icon}
              data-set-subtitle={set.subtitle}
              data-set-detail={set.detail}
              aria-haspopup="dialog"
            >
              <span class="play-card-icon">{set.icon}</span>
              <span class="play-card-title">{set.name}</span>
              <span class="play-card-subtitle">{set.subtitle}</span>
              <span class="play-card-detail">{set.detail}</span>
            </button>
          </div>
        ))}
      </div>
    </div>

    <!-- Explore section -->
    <div class="homepage-section">
      <h2 class="homepage-section-title">More Sets</h2>
      <p class="homepage-section-subtitle">Pick a themed set, then choose a mode to start.</p>
      <div class="themed-buttons">
        {themedGroup.map(set => (
          <div class="themed-set-wrap">
            <button
              type="button"
              class="themed-btn set-choice-card"
              data-set-card
              data-set-key={set.key}
              data-set-name={set.name}
              data-set-icon={set.icon}
              data-set-subtitle={set.countLabel}
              data-set-detail="Themed deep dive"
              aria-haspopup="dialog"
            >
              <span class="themed-btn-icon">{set.icon}</span>
              <span class="themed-btn-label">{set.name}</span>
              <span class="themed-btn-meta">{set.countLabel}</span>
            </button>
          </div>
        ))}
      </div>
    </div>

    <!-- What You'll Learn -->
    <div class="homepage-section">
      <h2 class="homepage-section-title">What You'll Learn</h2>
      <p class="homepage-learn-text">What's That Bug? features over 1,000 insect species photographed in the wild by citizen scientists. From common backyard beetles to rare tropical butterflies, every photo is research-grade verified. Whether you're a curious beginner or a seasoned entomologist, there's always a new bug to discover.</p>
    </div>

    <!-- What's New -->
    <div class="homepage-section">
      <h2 class="homepage-section-title">What's New</h2>
      <ol class="whats-new-list">
        {latestChangelog.map(entry => (
          <li class="whats-new-item">
            <span class="whats-new-date">{fmtChangelogDate(entry.data.date)}</span>
            {entry.data.tag && <span class="whats-new-tag">{entry.data.tag}</span>}
            <span class="whats-new-title">{entry.data.title}</span>
          </li>
        ))}
      </ol>
      <a href="/changelog" class="whats-new-more">See full timeline →</a>
    </div>
  </div>

  <div class="mode-overlay" id="mode-overlay" role="dialog" aria-modal="true" aria-labelledby="mode-overlay-title" hidden>
    <button type="button" class="mode-overlay-close" id="mode-overlay-close" aria-label="Close mode picker">&times;</button>
    <div class="mode-overlay-panel" id="mode-overlay-panel">
      <div class="mode-overlay-hero">
        <span class="mode-overlay-hero-icon" id="mode-overlay-icon"></span>
        <p class="mode-overlay-eyebrow">Choose your mode</p>
        <h2 id="mode-overlay-title"></h2>
        <p id="mode-overlay-subtitle"></p>
        <span id="mode-overlay-detail"></span>
      </div>
      <div class="mode-overlay-modes">
        {MODES.map(mode => (
          <a href="/" class="mode-overlay-mode" data-mode-link data-mode-key={mode.key}>
            <span class="mode-overlay-mode-icon">{mode.icon}</span>
            <strong>{mode.label}</strong>
            <span class="mode-overlay-mode-detail">{mode.detail}</span>
            <span class="mode-overlay-mode-desc">{mode.description}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "What's That Bug?",
    "description": "A free guess-the-bug game with 1,000+ species. Identify insects from real research-grade photos in this GeoGuessr-style quiz.",
    "url": "https://dewanggogte.com/games/bugs",
    "applicationCategory": "GameApplication",
    "genre": "Trivia",
    "operatingSystem": "Web",
    "browserRequirements": "Requires JavaScript",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Person",
      "name": "Dewang Gogte",
      "url": "https://dewanggogte.com"
    }
  }
  </script>

<script>
  const overlay = document.getElementById('mode-overlay');
  const panel = document.getElementById('mode-overlay-panel');
  const closeBtn = document.getElementById('mode-overlay-close');
  const iconEl = document.getElementById('mode-overlay-icon');
  const titleEl = document.getElementById('mode-overlay-title');
  const subtitleEl = document.getElementById('mode-overlay-subtitle');
  const detailEl = document.getElementById('mode-overlay-detail');
  let lastTrigger = null;

  function closeModeOverlay() {
    overlay.hidden = true;
    document.body.classList.remove('mode-overlay-open');
    if (lastTrigger) lastTrigger.focus();
  }

  function openModeOverlay(card) {
    lastTrigger = card;
    const setKey = card.dataset.setKey;
    const basePath = window.__BASE || '';
    iconEl.textContent = card.dataset.setIcon || '';
    titleEl.textContent = card.dataset.setName || '';
    subtitleEl.textContent = card.dataset.setSubtitle || '';
    detailEl.textContent = card.dataset.setDetail || '';
    overlay.querySelectorAll('[data-mode-link]').forEach((link) => {
      link.href = `${basePath}/${setKey}/${link.dataset.modeKey}/play`;
    });
    overlay.hidden = false;
    document.body.classList.add('mode-overlay-open');
    overlay.querySelector('[data-mode-link]')?.focus();
  }

  document.querySelectorAll('[data-set-card]').forEach((card) => {
    card.addEventListener('click', () => {
      openModeOverlay(card);
    });
  });

  closeBtn.addEventListener('click', closeModeOverlay);
  overlay.addEventListener('click', (event) => {
    if (!panel.contains(event.target)) closeModeOverlay();
  });
  document.addEventListener('keydown', (event) => {
    if (!overlay.hidden && event.key === 'Escape') closeModeOverlay();
  });
</script>

<script>
  import { getTodayET, loadDailyState, loadHistory, calculateStreaks } from '../scripts/daily-engine.js';

  try {
    const today = getTodayET();
    const link = document.getElementById('daily-link-bugs101');
    const bannerStatus = document.querySelector('.daily-banner-status');

    // Check bugs101 state for the banner
    const result = loadDailyState('bugs101', today);
    if (result && link) {
      if (result.solved) {
        link.textContent = `Solved ✓`;
        link.style.color = 'var(--success)';
      } else {
        link.textContent = 'Missed';
        link.style.color = 'var(--error)';
      }
    }

    // Show streak warning if applicable
    const history = loadHistory('bugs101');
    const streaks = calculateStreaks(history, today);
    if (streaks.playStreak >= 3 && !result && bannerStatus) {
      const warn = document.createElement('span');
      warn.className = 'streak-warning';
      warn.textContent = `${streaks.playStreak}-day streak at risk!`;
      warn.style.marginLeft = '8px';
      bannerStatus.appendChild(warn);
    }
  } catch { /* daily challenge not yet available */ }
</script>

<script>
  import { runOnboarding } from '../scripts/onboarding.js';
  import { maybeShowInterviewPrompt } from '../scripts/interview-prompt.js';
  import { maybeShowSupportPrompt } from '../scripts/support-prompt.js';
  runOnboarding();
  if (!maybeShowInterviewPrompt()) maybeShowSupportPrompt();
</script>

<script>
  // --- Player Stats Card ---
  try {
    const { getEarnedAchievements, getGenusCount, getGenusList, ACHIEVEMENT_DEFS } = await import('../scripts/achievements.js');
    const { migrateBestStorageKey } = await import('../scripts/game-engine.js');
    const stats = JSON.parse(localStorage.getItem('wtb_player_stats') || '{}');
    const genusCount = getGenusCount();
    const sessionCount = stats.session_count || 0;
    const achievements = getEarnedAchievements();

    // Only show stats card if player has at least 3 sessions
    if (sessionCount >= 3) {
      const statsCard = document.createElement('div');
      statsCard.className = 'player-stats-card';
      statsCard.innerHTML = `
        <div class="stats-row">
          <button class="stat-item stat-item-btn" data-modal="sessions">
            <span class="stat-value">${sessionCount}</span>
            <span class="stat-label">sessions</span>
          </button>
          <button class="stat-item stat-item-btn" data-modal="species">
            <span class="stat-value">${genusCount}</span>
            <span class="stat-label">genera ID'd</span>
          </button>
          <button class="stat-item stat-item-btn" data-modal="badges">
            <span class="stat-value">${achievements.length}</span>
            <span class="stat-label">badges</span>
          </button>
        </div>
      `;

      const container = document.querySelector('.container');
      const firstModeGroup = container.querySelector('.mode-group');
      if (firstModeGroup) {
        container.insertBefore(statsCard, firstModeGroup);
      }

      // --- Modal system ---
      const overlay = document.createElement('div');
      overlay.className = 'stats-modal-overlay';
      overlay.innerHTML = `
        <div class="stats-modal">
          <div class="stats-modal-header">
            <h2 class="stats-modal-title"></h2>
            <button class="stats-modal-close" aria-label="Close">&times;</button>
          </div>
          <div class="stats-modal-body"></div>
        </div>
      `;
      document.body.appendChild(overlay);

      const modalTitle = overlay.querySelector('.stats-modal-title');
      const modalBody = overlay.querySelector('.stats-modal-body');
      const closeBtn = overlay.querySelector('.stats-modal-close');

      function openModal(title, html) {
        modalTitle.textContent = title;
        modalBody.innerHTML = html;
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function closeModal() {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }
      closeBtn.addEventListener('click', closeModal);
      overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

      // --- Sessions modal ---
      function buildSessionsModal() {
        const lastPlayed = stats.last_played
          ? new Date(stats.last_played).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })
          : 'Unknown';

        // Gather best scores
        const scoreKeys = [
          { setKey: 'bugs_101', mode: 'classic', label: 'Bugs 101 Classic' },
          { setKey: 'bugs_101', mode: 'time_trial', label: 'Bugs 101 Time Trial' },
          { setKey: 'bugs_101', mode: 'streak', label: 'Bugs 101 Streak' },
          { setKey: 'all_bugs', mode: 'classic', label: 'All Bugs Classic' },
          { setKey: 'all_bugs', mode: 'time_trial', label: 'All Bugs Time Trial' },
          { setKey: 'all_bugs', mode: 'streak', label: 'All Bugs Streak' },
          { setKey: 'backyard_basics', mode: 'classic', label: 'Backyard Basics' },
          { setKey: 'tiny_terrors', mode: 'classic', label: 'Tiny Terrors' },
          { setKey: 'beetles', mode: 'classic', label: 'Beetles' },
          { setKey: 'butterflies_moths', mode: 'classic', label: 'Butterflies & Moths' },
          { setKey: 'spiders', mode: 'classic', label: 'Spiders' },
          { setKey: 'eye_candy', mode: 'classic', label: 'Eye Candy' },
        ];

        const scores = scoreKeys
          .map(s => ({ ...s, score: localStorage.getItem(migrateBestStorageKey(s.setKey, s.mode)) }))
          .filter(s => s.score);

        return `
          <div class="sessions-detail">
            <div class="sessions-summary">
              <div class="sessions-stat">
                <span class="sessions-stat-val">${sessionCount}</span>
                <span class="sessions-stat-lbl">Total Sessions</span>
              </div>
              <div class="sessions-stat">
                <span class="sessions-stat-val">${lastPlayed}</span>
                <span class="sessions-stat-lbl">Last Played</span>
              </div>
              <div class="sessions-stat">
                <span class="sessions-stat-val">${genusCount}</span>
                <span class="sessions-stat-lbl">Unique Genera</span>
              </div>
            </div>
            ${scores.length > 0 ? `
              <h3 class="sessions-section-title">Best Scores</h3>
              <div class="sessions-scores">
                ${scores.map(s => `
                  <div class="sessions-score-row">
                    <span class="sessions-score-label">${s.label}</span>
                    <span class="sessions-score-value">${s.score}</span>
                  </div>
                `).join('')}
              </div>
            ` : '<p style="color:var(--text-secondary);text-align:center;margin-top:16px;">Play more games to see your best scores here.</p>'}
          </div>
        `;
      }

      // --- Genus modal ---
      async function buildGenusModal() {
        const seenGenera = getGenusList();
        if (seenGenera.length === 0) {
          return '<p style="color:var(--text-secondary);text-align:center;padding:24px;">No genera identified yet. Play a game to start your collection!</p>';
        }

        // Load observations data
        const basePath = window.__BASE || '';
        const resp = await fetch(`${basePath}/data/observations.json`);
        const observations = await resp.json();

        // Build a lookup: genus name → best observation (prefer one with wikipedia_summary)
        const genusMap = new Map();
        for (const obs of observations) {
          const name = obs.taxon?.genus;
          if (!name || !seenGenera.includes(name)) continue;
          const existing = genusMap.get(name);
          if (!existing || (!existing.wikipedia_summary && obs.wikipedia_summary)) {
            genusMap.set(name, obs);
          }
        }

        const cards = seenGenera
          .filter(name => genusMap.has(name))
          .sort()
          .map(name => {
            const obs = genusMap.get(name);
            const common = obs.taxon?.genus_common || obs.taxon?.common_name || '';
            const summary = obs.wikipedia_summary
              ? obs.wikipedia_summary.slice(0, 100) + (obs.wikipedia_summary.length > 100 ? '...' : '')
              : obs.taxon?.order_common || '';
            return `
              <div class="species-card">
                <div class="species-card-img" style="background-image:url('${obs.photo_url}')"></div>
                <div class="species-card-info">
                  <span class="species-card-common">${common || name}</span>
                  <span class="species-card-sci">${name}</span>
                  <span class="species-card-blurb">${summary}</span>
                </div>
              </div>
            `;
          });

        return `<div class="species-grid">${cards.join('')}</div>`;
      }

      // --- Badges modal ---
      function badgeShareText(def) {
        const rarityLabel = { common: '', uncommon: '', rare: 'Rare ', very_rare: 'Very Rare ', epic: 'Epic ', legendary: 'Legendary ' };
        const prefix = rarityLabel[def.rarity] || '';
        return [
          `I just earned the ${prefix}"${def.name}" badge on What's That Bug!`,
          '',
          `${def.icon} ${def.name} — ${def.description}`,
          '',
          `${achievements.length}/${ACHIEVEMENT_DEFS.length} badges collected. Can you beat that?`,
          '',
          'https://dewanggogte.com/games/bugs/?ref=share',
        ].join('\n');
      }

      function buildBadgesModal() {
        const earnedIds = new Set(achievements.map(a => a.id));
        const rarityLabel = { common: 'Common', uncommon: 'Uncommon', rare: 'Rare', very_rare: 'Very Rare', epic: 'Epic', legendary: 'Legendary' };
        const rarityColor = { common: '#666', uncommon: '#059669', rare: '#3b6eb8', very_rare: '#a855f7', epic: '#c44b2b', legendary: '#b8953b' };

        const shareIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>';

        const cards = ACHIEVEMENT_DEFS.map(def => {
          const earned = earnedIds.has(def.id);
          const basePath = window.__BASE || '';
          return `
            <div class="badge-card ${earned ? '' : 'badge-locked'}">
              <img class="badge-card-img" src="${basePath}/badges/${def.id}.svg" alt="${def.name}" width="80" height="80" />
              <span class="badge-card-name">${def.name}</span>
              <span class="badge-card-desc">${def.description}</span>
              <span class="badge-card-rarity" style="color:${rarityColor[def.rarity] || '#666'}">${rarityLabel[def.rarity] || def.rarity}</span>
              ${earned ? `<button class="badge-share-btn" data-badge-id="${def.id}" title="Share this badge">${shareIcon} Share</button>` : ''}
            </div>
          `;
        });

        return `
          <div class="badge-summary">${achievements.length} of ${ACHIEVEMENT_DEFS.length} earned</div>
          <div class="badges-grid">${cards.join('')}</div>
        `;
      }

      function attachBadgeShareHandlers() {
        modalBody.querySelectorAll('.badge-share-btn').forEach(btn => {
          btn.addEventListener('click', async () => {
            const def = ACHIEVEMENT_DEFS.find(d => d.id === btn.dataset.badgeId);
            if (!def) return;
            const text = badgeShareText(def);
            if (typeof navigator !== 'undefined' && navigator.share) {
              try { await navigator.share({ text }); } catch {}
            } else {
              try {
                await navigator.clipboard.writeText(text);
                btn.innerHTML = '&#10003; Copied!';
              } catch {
                btn.textContent = 'Failed';
              }
              setTimeout(() => {
                const shareIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>';
                btn.innerHTML = `${shareIcon} Share`;
              }, 2000);
            }
          });
        });
      }

      // --- Click handlers ---
      statsCard.querySelectorAll('.stat-item-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const modal = btn.dataset.modal;
          if (modal === 'sessions') {
            openModal('Your Sessions', buildSessionsModal());
          } else if (modal === 'species') {
            openModal('Genus Collection', '<p style="text-align:center;padding:24px;color:var(--text-secondary);">Loading genera...</p>');
            const html = await buildGenusModal();
            modalBody.innerHTML = html;
          } else if (modal === 'badges') {
            openModal('Badge Collection', buildBadgesModal());
            attachBadgeShareHandlers();
          }
        });
      });
    }

    // Genus milestone — show once per milestone
    const milestones = [50, 100, 150, 200, 250, 500, 1000];
    const milestone = milestones.filter(m => genusCount >= m).pop();
    const lastCelebrated = parseInt(localStorage.getItem('wtb_last_milestone') || '0', 10);

    if (milestone && milestone > lastCelebrated) {
      localStorage.setItem('wtb_last_milestone', milestone.toString());
      localStorage.setItem('wtb_show_milestone', milestone.toString());
    }

    const pendingMilestone = localStorage.getItem('wtb_show_milestone');
    if (pendingMilestone) {
      localStorage.removeItem('wtb_show_milestone');
      const banner = document.createElement('div');
      banner.className = 'milestone-banner';
      banner.innerHTML = `🎉 You've identified <strong>${pendingMilestone}</strong> unique genera!`;
      const container = document.querySelector('.container');
      container.insertBefore(banner, container.firstChild);
      setTimeout(() => { banner.style.opacity = '0'; setTimeout(() => banner.remove(), 500); }, 5000);
    }
  } catch { /* ignore — non-critical UI enhancement */ }
</script>

<style is:global>
  .player-stats-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 20px;
  }

  .stats-row {
    display: flex;
    justify-content: space-around;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-item-btn {
    background: none;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    padding: 8px 16px;
    cursor: pointer;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }
  .stat-item-btn:hover {
    background: var(--bg);
    border-color: var(--border);
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .streak-warning {
    display: inline-block;
    margin-top: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--error);
