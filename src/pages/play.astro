---
import Base from '../layouts/Base.astro';
---
<Base
  title="Play — What's That Bug?"
  description="Guess the insect from its photo. Four choices, one correct answer. How well do you know your bugs?"
  canonicalPath="/play"
>
  <div id="game-container">
    <div class="container" style="text-align: center; padding-top: 80px;">
      <p class="subtitle">Loading bugs...</p>
    </div>
  </div>
  <script>
    import { initGame } from '../scripts/game-ui.js';
    initGame();
  </script>
</Base>
