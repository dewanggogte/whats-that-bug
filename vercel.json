{
  "rewrites": [
    { "source": "/t/s.js", "destination": "https://cloud.umami.is/script.js" },
    { "source": "/t/api/send", "destination": "https://cloud.umami.is/api/send" }
  ],
  "headers": [
    {
      "source": "/data/(observations|taxonomy|sets).json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/data/daily/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/data/daily/:date/:file",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
