# Google Apps Script webhook URL for feedback + game events
# Must be prefixed with PUBLIC_ for Astro to expose to client-side JS
PUBLIC_GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# GoatCounter site code (e.g., "whats-that-bug")
PUBLIC_GOATCOUNTER_ID=whats-that-bug
