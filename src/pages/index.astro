---
import Base from '../layouts/Base.astro';
import setsData from '../../public/data/sets.json';
import observations from '../../public/data/observations.json';

const SET_ICONS: Record<string, string> = {
  bugs_101: '🔰',
  bugs_101_time_trial: '⏱️',
  bugs_101_streak: '🎯',
  all_bugs: '🌍',
  time_trial: '⏱️',
  streak: '🎯',
  backyard_basics: '🏡',
  beetles: '🪲',
  butterflies_moths: '🦋',
  spiders: '🕷️',
  tiny_terrors: '😱',
};

const DIFFICULTY_LABELS: Record<string, { label: string; class: string }> = {
  beginner: { label: 'Beginner', class: 'diff-beginner' },
  intermediate: { label: 'Intermediate', class: 'diff-intermediate' },
  themed: { label: 'Themed', class: 'diff-themed' },
  expert: { label: 'Expert', class: 'diff-expert' },
};

function makeEntry(key: string, set: any) {
  const isBinary = set.scoring === 'binary';
  const uniqueCount = isBinary
    ? new Set(set.observation_ids.map((i: number) => observations[i]?.taxon?.order)).size
    : new Set(set.observation_ids.map((i: number) => observations[i]?.taxon?.species)).size;
  const countLabel = isBinary ? `${uniqueCount} types` : `${uniqueCount} species`;
  const diff = DIFFICULTY_LABELS[set.difficulty] || null;
  return { key, ...set, icon: SET_ICONS[key] || '🐛', countLabel, diff };
}

// Group 1: Bugs 101
const bugs101Group = [
  makeEntry('bugs_101_time_trial', setsData.bugs_101_time_trial),
  makeEntry('bugs_101_streak', setsData.bugs_101_streak),
  makeEntry('bugs_101', setsData.bugs_101),
];

// Group 2: All Bugs
const allBugsGroup = [
  makeEntry('time_trial', setsData.time_trial),
  makeEntry('streak', setsData.streak),
  makeEntry('all_bugs', setsData.all_bugs),
];

// Group 3: Themed Sets
const themedKeys = ['backyard_basics', 'tiny_terrors', 'beetles', 'butterflies_moths', 'spiders'];
const themedGroup = themedKeys.map(key => makeEntry(key, setsData[key]));
---
<Base title="What's That Bug? — Insect Identification Game">
  <div class="container">
    <div style="text-align: center; padding: 24px 0 8px;">
      <h1>🪲 What's That Bug?</h1>
      <p class="subtitle">Can you identify insects from their photos? Pick a set and find out.</p>
    </div>

    <div class="set-group">
      <h2 class="set-group-title">🔰 Bugs 101</h2>
      <p class="set-group-subtitle">Identify by type — beetle, spider, butterfly, and more.</p>
      <div class="set-grid set-grid-3">
        {bugs101Group.map(set => (
          <a href={`/play?set=${set.key}`} class="set-card">
            <div class="set-card-thumb" style="display:flex;align-items:center;justify-content:center;font-size:48px;">
              {set.icon}
            </div>
            <div class="set-card-body">
              <h3>{set.name}</h3>
              <p>{set.description}</p>
              <div class="set-card-meta">
                <span>{set.countLabel}</span>
                <span id={`best-${set.key}`}></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="set-group">
      <h2 class="set-group-title">🌍 All Bugs</h2>
      <p class="set-group-subtitle">Species-level identification from 1,000+ bugs worldwide.</p>
      <div class="set-grid set-grid-3">
        {allBugsGroup.map(set => (
          <a href={`/play?set=${set.key}`} class="set-card">
            <div class="set-card-thumb" style="display:flex;align-items:center;justify-content:center;font-size:48px;">
              {set.icon}
            </div>
            <div class="set-card-body">
              <h3>
                {set.name}
                {set.diff && <span class={`diff-badge ${set.diff.class}`}>{set.diff.label}</span>}
              </h3>
              <p>{set.description}</p>
              <div class="set-card-meta">
                <span>{set.countLabel}</span>
                <span id={`best-${set.key}`}></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="set-group">
      <h2 class="set-group-title">Themed Sets</h2>
      <p class="set-group-subtitle">Dive deeper into specific groups.</p>
      <div class="set-grid">
        {themedGroup.map(set => (
          <a href={`/play?set=${set.key}`} class="set-card">
            <div class="set-card-thumb" style="display:flex;align-items:center;justify-content:center;font-size:48px;">
              {set.icon}
            </div>
            <div class="set-card-body">
              <h3>
                {set.name}
                {set.diff && <span class={`diff-badge ${set.diff.class}`}>{set.diff.label}</span>}
              </h3>
              <p>{set.description}</p>
              <div class="set-card-meta">
                <span>{set.countLabel}</span>
                <span id={`best-${set.key}`}></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script>
    // Show best scores from localStorage
    document.querySelectorAll('[id^="best-"]').forEach(el => {
      const setKey = el.id.replace('best-', '');
      const storageKey = `best_${setKey}`;
      const best = localStorage.getItem(storageKey);
      if (best) {
        const isStreak = setKey === 'streak' || setKey === 'bugs_101_streak';
        const label = isStreak ? `Best: ${best} streak` : `Best: ${best}`;
        el.textContent = label;
        el.style.color = 'var(--accent)';
        el.style.fontWeight = '600';
      }
    });
  </script>
</Base>
